  "views": {
    "overview": {
      "title": "Results",
      "transformation": {
        "fields": [
          "companyName",
          "website",
          "phone",
          "email",
          "city",
          "country",
          "sectors",
          "rating",
          "url",
          "address"
        ]
      },
      "display": {
        "component": "table",
        "properties": {
          "companyName": { "label": "Company", "format": "text" },
          "website":     { "label": "Website", "format": "link" },
          "phone":       { "label": "Phone",   "format": "text" },
          "email":       { "label": "Email",   "format": "text" },
          "city":        { "label": "City",    "format": "text" },
          "country":     { "label": "Country", "format": "text" },
          "sectors":     { "label": "Sectors", "format": "text" },
          "rating":      { "label": "Rating",  "format": "number" },
          "url":         { "label": "Profile", "format": "link" },
          "address":     { "label": "Address", "format": "text" }
        }
      }
