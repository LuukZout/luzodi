      "title": "Profile URL",
      "type": "string",
      "description": "URL of the company profile on b2bstars.com."
    },
    "website": {
      "title": "Website",
      "type": "string",
      "description": "Company website URL."
    },
    "phone": {
      "title": "Phone",
      "type": "string",
      "description": "Company phone number (may be empty if hidden behind paywall)."
    },
    "email": {
      "title": "Email",
      "type": "string",
      "description": "Company email address."
    },
    "address": {
      "title": "Address",
      "type": "string",
      "description": "Company street address."
    },
    "city": {
      "title": "City",
      "type": "string",
      "description": "City where the company is located."
    },
    "country": {
      "title": "Country",
      "type": "string",
      "description": "Country where the company is located."
    },
    "sectors": {
      "title": "Sectors",
      "type": "string",
      "description": "Comma-separated list of industry sectors."
    },
    "rating": {
      "title": "Rating",
      "type": "integer",
      "description": "Star rating (0–5) from the Kompass profile."
